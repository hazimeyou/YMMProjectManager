<UserControl
    x:Class="YMMProjectManager.Settings.YMMProjectManagerSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="760"
    Height="520">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="探索フォルダ（複数可）" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal">
                <ListBox x:Name="FoldersList" Width="520" Height="100" Margin="0,0,8,0" />
                <StackPanel>
                    <Button Content="追加" Width="90" Margin="0,0,0,8" Click="OnAddFolderClick" />
                    <Button Content="削除" Width="90" Click="OnRemoveFolderClick" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="保存" Width="90" Margin="0,0,8,0" Click="OnSaveClick" />
            <Button Content="再読込" Width="90" Click="OnReloadClick" />
        </StackPanel>

        <TextBlock x:Name="SummaryText" DockPanel.Dock="Top" Margin="0,0,0,6" />
    </DockPanel>
</UserControl>
