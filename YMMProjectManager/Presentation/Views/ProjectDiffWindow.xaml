<Window
    x:Class="YMMProjectManager.Presentation.Views.ProjectDiffWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:YMMProjectManager.Presentation.Views"
    Title="{Binding Title}"
    Width="1400"
    Height="900"
    WindowState="Maximized"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,6" Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
        <TextBlock Grid.Row="1" Margin="0,0,0,8" Text="{Binding MatchStatisticsText}" FontSize="11" Opacity="0.85" TextWrapping="Wrap" />
        <Expander Grid.Row="2" Header="Preview UX Controls" IsExpanded="False" Margin="0,0,0,8">
            <Border BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Padding="8">
                <StackPanel>
                    <WrapPanel>
                        <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Width="220" Text="{Binding FilterSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <CheckBox Content="Changed only" IsChecked="{Binding ChangedOnlyFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                        <CheckBox Content="Warning only" IsChecked="{Binding WarningOnlyFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                        <TextBlock Text="ChangeType:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="120" ItemsSource="{Binding ChangeTypeFilterOptions}" SelectedItem="{Binding SelectedChangeTypeFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                        <TextBlock Text="Semantic:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="120" ItemsSource="{Binding SemanticFilterOptions}" SelectedItem="{Binding SelectedSemanticCategoryFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                    </WrapPanel>
                    <WrapPanel Margin="0,6,0,0">
                        <TextBlock Text="Path:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Width="220" Text="{Binding SelectedPathFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBlock Text="Group:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Width="180" Text="{Binding SelectedGroupFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Content="Clear Filters" Width="100" Click="OnClearFiltersClick" Margin="0,0,8,0"/>
                        <TextBlock Text="Grouping:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Width="120" ItemsSource="{Binding GroupingModeOptions}" SelectedItem="{Binding SelectedGroupingMode, Mode=TwoWay}" Margin="0,0,8,0"/>
                        <Button Content="Expand All" Width="90" Click="OnExpandAllGroupsClick" Margin="0,0,6,0"/>
                        <Button Content="Collapse All" Width="90" Click="OnCollapseAllGroupsClick"/>
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0" Text="{Binding LastFilterDiagnostics}" FontSize="11" Opacity="0.85"/>
                    <TextBlock Margin="0,2,0,0" Text="{Binding ActiveFilterSummary}" FontSize="11" Opacity="0.85"/>
                    <TextBlock Margin="0,2,0,0" Text="{Binding NoMatchStateText}" FontSize="11" Foreground="DarkOrange" TextWrapping="Wrap"/>
                    <Separator Margin="0,8,0,8"/>
                    <TextBlock Text="Snapshot Browser (Preview)" FontWeight="SemiBold"/>
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="Latest Validation:" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SnapshotBrowser.LatestValidationState}" Margin="0,0,12,0"/>
                        <TextBlock Text="Snapshot Count:" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SnapshotBrowser.SnapshotList.Count}" Margin="0,0,12,0"/>
                        <TextBlock Text="Comparison Candidates:" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SnapshotBrowser.ComparisonCandidates.Count}"/>
                    </WrapPanel>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid Grid.Column="0"
                                  Height="140"
                                  ItemsSource="{Binding SnapshotBrowser.SnapshotList}"
                                  SelectedItem="{Binding SelectedSnapshotListItem, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding SnapshotName}" Width="*"/>
                                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt}" Width="150"/>
                                <DataGridTextColumn Header="Source" Binding="{Binding SourceProject}" Width="130"/>
                                <DataGridTextColumn Header="Hash" Binding="{Binding SnapshotHash}" Width="130"/>
                                <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <WrapPanel>
                                <Button Content="Set Old" Width="90" Margin="0,0,6,0" Click="OnSetOldSnapshotClick"/>
                                <Button Content="Set New" Width="90" Margin="0,0,6,0" Click="OnSetNewSnapshotClick"/>
                                <Button Content="Swap" Width="80" Margin="0,0,6,0" Click="OnSwapSnapshotSelectionClick"/>
                                <Button Content="Clear" Width="80" Click="OnClearSnapshotSelectionClick"/>
                            </WrapPanel>
                            <Button Margin="0,6,0,0" Width="220" Content="Compare Selected Snapshots" Click="OnRunSnapshotCompareClick" IsEnabled="{Binding SnapshotBrowser.CanCompare}"/>
                            <TextBlock Margin="0,8,0,0" Text="{Binding SnapshotBrowser.CompareSummaryText}" TextWrapping="Wrap" FontSize="11"/>
                            <TextBlock Margin="0,4,0,0" Text="{Binding SnapshotBrowser.SnapshotBrowserMessage}" TextWrapping="Wrap" FontSize="11" Opacity="0.8"/>
                            <TextBlock Margin="0,4,0,0" Text="{Binding SnapshotCompareSummaryText}" TextWrapping="Wrap" FontSize="11" Foreground="DarkSlateGray"/>
                            <TextBlock Margin="0,6,0,0" Text="{Binding SnapshotBrowser.LastCompareStatusText}" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,2,0,0" Text="{Binding SnapshotBrowser.LastCompareResultSummary}" TextWrapping="Wrap" FontSize="11"/>
                            <TextBlock Margin="0,2,0,0" Text="{Binding SnapshotBrowser.LastCompareErrorText}" TextWrapping="Wrap" FontSize="11" Foreground="DarkOrange"/>
                            <TextBlock Margin="0,2,0,0" Text="{Binding SnapshotBrowser.LastCompareDiagnosticsPath}" TextWrapping="Wrap" FontSize="10" Opacity="0.8"/>
                            <TextBlock Margin="0,2,0,0" Text="{Binding SnapshotBrowser.LastCompareTimestamp, StringFormat=Last Compare: {0:yyyy-MM-dd HH:mm:ss}}" TextWrapping="Wrap" FontSize="10" Opacity="0.8"/>
                            <TextBlock Margin="0,4,0,0" Text="{Binding ManualValidationSessionId, StringFormat=Validation Session: {0}}" TextWrapping="Wrap" FontSize="10" Opacity="0.8"/>
                            <TextBlock Margin="0,2,0,0" Text="{Binding LatestManualValidationLogPath}" TextWrapping="Wrap" FontSize="10" Opacity="0.8"/>
                            <TextBlock Margin="0,2,0,0" Text="{Binding LatestManualValidationSummary}" TextWrapping="Wrap" FontSize="10" Opacity="0.8"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Expander>

        <TabControl Grid.Row="3">
            <TabItem Header="一覧表示">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding YmmDiffEntries}" SelectedItem="{Binding SelectedYmmDiffEntry, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="種別" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="項目" Binding="{Binding Field}" Width="90" />
                                <DataGridTextColumn Header="T" Binding="{Binding TimelineIndex}" Width="45" />
                                <DataGridTextColumn Header="L" Binding="{Binding Layer}" Width="45" />
                                <DataGridTextColumn Header="F" Binding="{Binding Frame}" Width="80" />
                                <DataGridTextColumn Header="スコープ" Binding="{Binding Scope}" Width="*" />
                                <DataGridTextColumn Header="変更前" Binding="{Binding Before}" Width="2*" />
                                <DataGridTextColumn Header="変更後" Binding="{Binding After}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding JsonDiffEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="種別" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="パス" Binding="{Binding Scope}" Width="*" />
                                <DataGridTextColumn Header="変更前" Binding="{Binding Before}" Width="2*" />
                                <DataGridTextColumn Header="変更後" Binding="{Binding After}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <ScrollViewer Grid.Column="1" Margin="8,0,0,0">
                        <ItemsControl ItemsSource="{Binding DiffGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="▼ " />
                                                <Run Text="{Binding GroupName}" />
                                                <Run Text=" (" />
                                                <Run Text="{Binding Count}" />
                                                <Run Text=")" />
                                            </TextBlock>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="8,2,0,2" Text="{Binding Kind}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="タイムライン表示">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="純正タイムラインホスト" FontWeight="SemiBold" Margin="0,0,12,0" />
                                <TextBlock Text="アダプター種別:" Margin="0,0,4,0" />
                                <ComboBox Width="170" ItemsSource="{Binding AdapterKindOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedAdapterKind, Mode=TwoWay}" Margin="0,0,12,0" />
                                <TextBlock Text="アダプター:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.AdapterDisplayName}" Margin="0,0,12,0" />
                                <TextBlock Text="状態:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineStatus}" Margin="0,0,12,0" />
                                <TextBlock Text="利用可否:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.IsAvailable}" Margin="0,0,12,0" />
                                <TextBlock Text="フォールバック:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.FallbackActive}" Margin="0,0,12,0" />
                                <TextBlock Text="シーン:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineActiveScene}" Margin="0,0,12,0" />
                                <TextBlock Text="タイムライン:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineActiveTimeline}" />
                                <TextBlock Text="実行環境:" Margin="12,0,4,0" />
                                <TextBlock Text="{Binding RuntimeEnvironmentText}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="同期状態:" Margin="0,0,4,0" />
                                <ComboBox Width="130" ItemsSource="{Binding SyncStateOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedSyncState, Mode=TwoWay}" Margin="0,0,12,0" />
                                <TextBlock Text="タイムラインモード:" Margin="0,0,4,0" />
                                <ComboBox Width="130" ItemsSource="{Binding TimelineModeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedTimelineMode, Mode=TwoWay}" Margin="0,0,12,0" />
                                <TextBlock Text="現在フレーム:" Margin="0,0,4,0" />
                                <TextBox Width="90" Text="{Binding PureTimelineHost.CurrentFrame, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                <Button Content="フレーム同期→DiffTL" Width="130" Click="OnSyncFrameClick" Margin="0,0,6,0" />
                                <Button Content="現在フレームへ移動" Width="120" Click="OnGoToCurrentFrameClick" Margin="0,0,6,0" />
                                <Button Content="現在フレームを中央表示" Width="140" Click="OnCenterCurrentFrameClick" Margin="0,0,6,0" />
                                <Button Content="最寄りの差分へ" Width="100" Click="OnNearestDiffClick" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="先頭差分" Width="90" Click="OnFirstDiffClick" Margin="0,0,6,0" />
                                <Button Content="末尾差分" Width="90" Click="OnLastDiffClick" Margin="0,0,6,0" />
                                <Button Content="前の差分(現在フレーム基準)" Width="170" Click="OnPrevFromFrameClick" Margin="0,0,6,0" />
                                <Button Content="次の差分(現在フレーム基準)" Width="170" Click="OnNextFromFrameClick" Margin="0,0,12,0" />
                                <TextBlock Text="同期:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineSyncState}" Margin="0,0,12,0" />
                                <TextBlock Text="モード:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineMode}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="初期化回数:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.InitializeCount}" Margin="0,0,12,0" />
                                <TextBlock Text="解放回数:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.DisposeCount}" Margin="0,0,12,0" />
                                <TextBlock Text="解放失敗:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.DisposeFailureCount}" Margin="0,0,12,0" />
                                <TextBlock Text="アクティブホスト:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.ActiveHostCount}" />
                                <Button Content="診断ホストを開く" Width="130" Margin="12,0,0,0" Click="OnOpenExperimentalHostClick" />
                            </StackPanel>

                            <TextBlock Text="{Binding PureTimelineSelection, StringFormat=選択中: {0}}" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding PureTimelineHost.LastError, StringFormat=最終エラー: {0}}" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding PureTimelineHost.LastAction}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <views:DiffTimelineView Grid.Row="1" DataContext="{Binding TimelineViewModel}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
