<Window
    x:Class="YMMProjectManager.Presentation.Views.ProjectDiffWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:YMMProjectManager.Presentation.Views"
    Title="{Binding Title}"
    Width="1400"
    Height="900"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,6" Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
        <TextBlock Grid.Row="1" Margin="0,0,0,8" Text="{Binding MatchStatisticsText}" FontSize="11" Opacity="0.85" TextWrapping="Wrap" />

        <TabControl Grid.Row="2">
            <TabItem Header="List View">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding YmmDiffEntries}" SelectedItem="{Binding SelectedYmmDiffEntry, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="90" />
                                <DataGridTextColumn Header="T" Binding="{Binding TimelineIndex}" Width="45" />
                                <DataGridTextColumn Header="L" Binding="{Binding Layer}" Width="45" />
                                <DataGridTextColumn Header="F" Binding="{Binding Frame}" Width="80" />
                                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="*" />
                                <DataGridTextColumn Header="Before" Binding="{Binding Before}" Width="2*" />
                                <DataGridTextColumn Header="After" Binding="{Binding After}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding JsonDiffEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="Path" Binding="{Binding Scope}" Width="*" />
                                <DataGridTextColumn Header="Before" Binding="{Binding Before}" Width="2*" />
                                <DataGridTextColumn Header="After" Binding="{Binding After}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <ScrollViewer Grid.Column="1" Margin="8,0,0,0">
                        <ItemsControl ItemsSource="{Binding DiffGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="▼ " />
                                                <Run Text="{Binding GroupName}" />
                                                <Run Text=" (" />
                                                <Run Text="{Binding Count}" />
                                                <Run Text=")" />
                                            </TextBlock>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="8,2,0,2" Text="{Binding Kind}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Timeline View">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#335" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8" Background="#F8FAFF">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Pure Timeline Host" FontWeight="SemiBold" Margin="0,0,12,0" />
                                <TextBlock Text="Adapter:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.DisplayName}" Margin="0,0,12,0" />
                                <TextBlock Text="Status:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.Status}" Margin="0,0,12,0" />
                                <TextBlock Text="IsAvailable:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineHost.IsAvailable}" Margin="0,0,12,0" />
                                <TextBlock Text="Scene:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineActiveScene}" Margin="0,0,12,0" />
                                <TextBlock Text="Timeline:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineActiveTimeline}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Sync State:" Margin="0,0,4,0" />
                                <ComboBox Width="130" ItemsSource="{Binding SyncStateOptions}" SelectedItem="{Binding SelectedSyncState, Mode=TwoWay}" Margin="0,0,12,0" />
                                <TextBlock Text="Timeline Mode:" Margin="0,0,4,0" />
                                <ComboBox Width="130" ItemsSource="{Binding TimelineModeOptions}" SelectedItem="{Binding SelectedTimelineMode, Mode=TwoWay}" Margin="0,0,12,0" />
                                <TextBlock Text="Current Frame:" Margin="0,0,4,0" />
                                <TextBox Width="90" Text="{Binding PureTimelineHost.CurrentFrame, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                <Button Content="Sync Frame -> DiffTL" Width="130" Click="OnSyncFrameClick" Margin="0,0,6,0" />
                                <Button Content="Go To Current" Width="110" Click="OnGoToCurrentFrameClick" Margin="0,0,6,0" />
                                <Button Content="Center Current" Width="110" Click="OnCenterCurrentFrameClick" Margin="0,0,6,0" />
                                <Button Content="Nearest Diff" Width="100" Click="OnNearestDiffClick" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="First Diff" Width="90" Click="OnFirstDiffClick" Margin="0,0,6,0" />
                                <Button Content="Last Diff" Width="90" Click="OnLastDiffClick" Margin="0,0,6,0" />
                                <Button Content="Prev From Frame" Width="120" Click="OnPrevFromFrameClick" Margin="0,0,6,0" />
                                <Button Content="Next From Frame" Width="120" Click="OnNextFromFrameClick" Margin="0,0,12,0" />
                                <TextBlock Text="Sync:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineSyncState}" Margin="0,0,12,0" />
                                <TextBlock Text="Mode:" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding PureTimelineMode}" />
                            </StackPanel>

                            <TextBlock Text="{Binding PureTimelineSelection, StringFormat=Selected: {0}}" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding PureTimelineHost.LastAction}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <views:DiffTimelineView Grid.Row="1" DataContext="{Binding TimelineViewModel}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
