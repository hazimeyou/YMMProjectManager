<Window
    x:Class="YMMProjectManager.Presentation.Views.ProjectDiffWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:YMMProjectManager.Presentation.Views"
    Title="{Binding Title}"
    Width="1400"
    Height="900"
    WindowState="Maximized"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="CompactLabelTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="CompactValueTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.85" />
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
            <TextBlock Margin="0,2,0,0" Text="{Binding MatchStatisticsText}" FontSize="11" Opacity="0.85" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Padding="6" Margin="0,0,0,4">
            <StackPanel>
                <TextBlock Text="履歴比較" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3" />
                <WrapPanel>
                    <Button Content="履歴を比較" Width="92" Margin="0,0,6,0" Click="OnRunSnapshotCompareClick" IsEnabled="{Binding SnapshotBrowser.CanCompare}"/>
                    <Button Content="読み取り専用" Width="96" Margin="0,0,12,0" IsEnabled="False"/>
                    <Button Content="表示設定" Width="84" Margin="0,0,6,0" Click="OnExpandAllGroupsClick"/>
                </WrapPanel>
                <Expander Header="詳細操作" IsExpanded="False" Margin="0,6,0,0">
                    <WrapPanel Margin="0,4,0,0">
                        <Button Content="Set Old" Width="78" Margin="0,0,6,0" Click="OnSetOldSnapshotClick"/>
                        <Button Content="Set New" Width="78" Margin="0,0,6,0" Click="OnSetNewSnapshotClick"/>
                        <Button Content="Swap" Width="66" Margin="0,0,6,0" Click="OnSwapSnapshotSelectionClick"/>
                        <Button Content="Save Session" Width="94" Margin="0,0,6,0" Click="OnSaveCompareSessionClick"/>
                        <Button Content="Restore Session" Width="106" Margin="0,0,6,0" Click="OnRestoreCompareSessionClick"/>
                        <Button Content="Clear" Width="66" Click="OnClearSnapshotSelectionClick"/>
                    </WrapPanel>
                </Expander>
                <WrapPanel Margin="0,4,0,0">
                    <TextBlock Text="読み取り専用: 復元・適用は無効です" FontSize="11" Opacity="0.85"/>
                </WrapPanel>
                <TextBlock Margin="0,3,0,0" Text="{Binding SnapshotBrowser.LastCompareStatusText}" FontSize="11" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Expander Grid.Row="2" Header="Filter / Grouping" IsExpanded="False" Margin="0,0,0,4">
            <Border BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Padding="5">
            <StackPanel>
                <WrapPanel>
                    <TextBlock Text="Search:" Style="{StaticResource CompactLabelTextStyle}"/>
                    <TextBox Width="190" Text="{Binding FilterSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <CheckBox Content="Changed only" IsChecked="{Binding ChangedOnlyFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                    <CheckBox Content="Warning only" IsChecked="{Binding WarningOnlyFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                    <TextBlock Text="ChangeType:" Style="{StaticResource CompactLabelTextStyle}"/>
                    <ComboBox Width="110" ItemsSource="{Binding ChangeTypeFilterOptions}" SelectedItem="{Binding SelectedChangeTypeFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                    <TextBlock Text="Semantic:" Style="{StaticResource CompactLabelTextStyle}"/>
                    <ComboBox Width="110" ItemsSource="{Binding SemanticFilterOptions}" SelectedItem="{Binding SelectedSemanticCategoryFilter, Mode=TwoWay}" Margin="0,0,8,0"/>
                    <TextBlock Text="Grouping:" Style="{StaticResource CompactLabelTextStyle}"/>
                    <ComboBox Width="110" ItemsSource="{Binding GroupingModeOptions}" SelectedItem="{Binding SelectedGroupingMode, Mode=TwoWay}" Margin="0,0,8,0"/>
                    <Button Content="Clear" Width="66" Click="OnClearFiltersClick" Margin="0,0,6,0"/>
                    <Button Content="Expand" Width="66" Click="OnExpandAllGroupsClick" Margin="0,0,6,0"/>
                    <Button Content="Collapse" Width="70" Click="OnCollapseAllGroupsClick"/>
                </WrapPanel>
                <TextBlock Margin="0,4,0,0" Text="{Binding ActiveFilterSummary}" FontSize="11" Opacity="0.85"/>
                <TextBlock Margin="0,2,0,0" Text="{Binding NoMatchStateText}" FontSize="11" Foreground="DarkOrange" TextWrapping="Wrap"/>
            </StackPanel>
            </Border>
        </Expander>

        <Border Grid.Row="3" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Padding="5" Margin="0,0,0,6">
            <StackPanel>
                <WrapPanel>
                    <TextBlock Text="{Binding RowWindowSummaryText}" Style="{StaticResource CompactValueTextStyle}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding CompactRenderDiagnosticsText}" Style="{StaticResource CompactValueTextStyle}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding IsLargeResultMode, StringFormat=Large Result: {0}}" Style="{StaticResource CompactValueTextStyle}" Margin="0,0,6,0"/>
                    <Button Content="さらに表示" Width="86" Margin="0,0,6,0" Click="OnLoadMoreRowsClick" IsEnabled="{Binding CanLoadMoreRows}" />
                    <Button Content="表示リセット" Width="86" Click="OnResetRowWindowClick" />
                </WrapPanel>
                <Expander Header="Advanced / Diagnostics" IsExpanded="False" Margin="0,6,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding VirtualizationRecommendationText}" FontSize="11" Foreground="DarkGoldenrod" TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding LastFilterDiagnostics}" FontSize="10" Opacity="0.85" TextWrapping="Wrap"/>
                        <TextBlock Margin="0,2,0,0" Text="{Binding DiagnosticsDetailsText}" FontSize="10" Opacity="0.85" TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="4">
            <TabItem Header="一覧表示">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding YmmDiffEntries}" SelectedItem="{Binding SelectedYmmDiffEntry, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="種別" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="項目" Binding="{Binding Field}" Width="90" />
                                <DataGridTextColumn Header="T" Binding="{Binding TimelineIndex}" Width="45" />
                                <DataGridTextColumn Header="L" Binding="{Binding Layer}" Width="45" />
                                <DataGridTextColumn Header="F" Binding="{Binding Frame}" Width="80" />
                                <DataGridTextColumn Header="スコープ" Binding="{Binding Scope}" Width="*" />
                                <DataGridTextColumn Header="変更前" Binding="{Binding Before}" Width="2*" />
                                <DataGridTextColumn Header="変更後" Binding="{Binding After}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding JsonDiffEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="種別" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="パス" Binding="{Binding Scope}" Width="*" />
                                <DataGridTextColumn Header="変更前" Binding="{Binding Before}" Width="2*" />
                                <DataGridTextColumn Header="変更後" Binding="{Binding After}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <ScrollViewer Grid.Column="1" Margin="8,0,0,0">
                        <StackPanel>
                            <Expander Header="Diff Groups" IsExpanded="True">
                                <ItemsControl ItemsSource="{Binding DiffGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander IsExpanded="True" Margin="0,0,0,6">
                                                <Expander.Header>
                                                    <TextBlock FontWeight="SemiBold">
                                                        <Run Text="▼ " />
                                                        <Run Text="{Binding GroupName}" />
                                                        <Run Text=" (" />
                                                        <Run Text="{Binding Count}" />
                                                        <Run Text=")" />
                                                    </TextBlock>
                                                </Expander.Header>
                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="8,2,0,2" Text="{Binding Kind}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>

                            <Expander Header="Snapshot Browser / Sessions" IsExpanded="False" Margin="0,8,0,0">
                                <StackPanel>
                                    <WrapPanel Margin="0,0,0,4">
                                        <TextBlock Text="Validation:" Style="{StaticResource CompactLabelTextStyle}"/>
                                        <TextBlock Text="{Binding SnapshotBrowser.LatestValidationState}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Snapshots:" Style="{StaticResource CompactLabelTextStyle}"/>
                                        <TextBlock Text="{Binding SnapshotBrowser.SnapshotList.Count}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Candidates:" Style="{StaticResource CompactLabelTextStyle}"/>
                                        <TextBlock Text="{Binding SnapshotBrowser.ComparisonCandidates.Count}"/>
                                    </WrapPanel>
                                    <ListBox Height="90" ItemsSource="{Binding SnapshotBrowser.LatestCompareSessions}" SelectedItem="{Binding SnapshotBrowser.SelectedSession, Mode=TwoWay}" SelectionChanged="OnSessionSelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CompareSummary}" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Margin="0,4,0,0" Text="{Binding SnapshotBrowser.SelectedSessionSummary}" FontSize="10" Opacity="0.8" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="タイムライン表示">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Expander Grid.Row="0" Header="Timeline Integration (Advanced)" IsExpanded="False" Margin="0,0,0,8">
                        <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="8" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                            <StackPanel>
                                <WrapPanel>
                                    <TextBlock Text="アダプター:" Style="{StaticResource CompactLabelTextStyle}" />
                                    <ComboBox Width="170" ItemsSource="{Binding AdapterKindOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedAdapterKind, Mode=TwoWay}" Margin="0,0,12,0" />
                                    <TextBlock Text="状態:" Style="{StaticResource CompactLabelTextStyle}" />
                                    <TextBlock Text="{Binding PureTimelineStatus}" Margin="0,0,12,0" />
                                    <TextBlock Text="同期状態:" Style="{StaticResource CompactLabelTextStyle}" />
                                    <ComboBox Width="130" ItemsSource="{Binding SyncStateOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedSyncState, Mode=TwoWay}" Margin="0,0,12,0" />
                                    <TextBlock Text="モード:" Style="{StaticResource CompactLabelTextStyle}" />
                                    <ComboBox Width="130" ItemsSource="{Binding TimelineModeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedTimelineMode, Mode=TwoWay}" Margin="0,0,12,0" />
                                </WrapPanel>
                                <WrapPanel Margin="0,6,0,0">
                                    <Button Content="フレーム同期→DiffTL" Width="130" Click="OnSyncFrameClick" Margin="0,0,6,0" />
                                    <Button Content="現在フレームへ移動" Width="120" Click="OnGoToCurrentFrameClick" Margin="0,0,6,0" />
                                    <Button Content="現在フレームを中央表示" Width="140" Click="OnCenterCurrentFrameClick" Margin="0,0,6,0" />
                                    <Button Content="最寄りの差分へ" Width="100" Click="OnNearestDiffClick" Margin="0,0,6,0" />
                                    <Button Content="先頭差分" Width="90" Click="OnFirstDiffClick" Margin="0,0,6,0" />
                                    <Button Content="末尾差分" Width="90" Click="OnLastDiffClick" Margin="0,0,6,0" />
                                    <Button Content="前の差分" Width="90" Click="OnPrevFromFrameClick" Margin="0,0,6,0" />
                                    <Button Content="次の差分" Width="90" Click="OnNextFromFrameClick" />
                                    <Button Content="Scene-aware調査" Width="120" Margin="12,0,0,0" Click="OnOpenSceneAwareHistoryPreviewInvestigationClick" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <views:DiffTimelineView Grid.Row="1" DataContext="{Binding TimelineViewModel}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
