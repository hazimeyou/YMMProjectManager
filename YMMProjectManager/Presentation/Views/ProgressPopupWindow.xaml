<Window
    x:Class="YMMProjectManager.Presentation.Views.ProgressPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="処理中"
    Width="340"
    Height="130"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="ToolWindow">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}"
            TextWrapping="Wrap"
            Margin="0,0,0,10" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar
                Height="16"
                Minimum="0"
                Maximum="100"
                Value="{Binding Percent, RelativeSource={RelativeSource AncestorType=Window}}" />
            <TextBlock
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Text="{Binding Percent, RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0:0}%}" />
        </Grid>
    </Grid>
</Window>
