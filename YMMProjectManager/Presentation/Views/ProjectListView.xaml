<UserControl
    x:Class="YMMProjectManager.Presentation.Views.ProjectListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="clr-namespace:YMMProjectManager.Presentation.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="OnLoaded"
    AllowDrop="True"
    PreviewDragOver="OnPreviewDragOver"
    Drop="OnDrop"
    MinWidth="320"
    MinHeight="240">

    <Grid Margin="8">
        <DockPanel>
            <!-- 基本操作: プロジェクト一覧の追加・削除・起動を行う。 -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button Content="追加" Width="90" Margin="0,0,8,0" Command="{Binding AddCommand}" />
                <Button Content="削除" Width="90" Margin="0,0,8,0" Command="{Binding RemoveCommand}" />
                <Button Content="開く" Width="90" Margin="0,0,8,0" Command="{Binding OpenCommand}" />
            </StackPanel>

            <!-- YMM 本体と連携する操作は、通常の一覧操作と分けて配置する。 -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button
                    Content="選択したプロジェクトを同梱"
                    MinWidth="139"
                    Margin="0,0,8,0"
                    Command="{Binding PackageSelectedProjectCommand}" />
                <Button
                    Content="現在のプロジェクトを同梱"
                    MinWidth="139"
                    Margin="0,0,8,0"
                    Command="{Binding PackageOpenedProjectCommand}" />
                <Button
                    Content="ymmpx展開"
                    MinWidth="110"
                    Margin="0,0,8,0"
                    Command="{Binding ExtractBundleCommand}" />
                <Button
                    Content="再リンク"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Command="{Binding OpenRelinkWindowCommand}" />
                <Button
                    Content="サムネイル生成"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Command="{Binding GenerateThumbnailsFastCommand}" />
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" Text="{Binding BundleStatus}" Margin="0,0,0,6" />
            <ProgressBar DockPanel.Dock="Top" Height="20" Minimum="0" Maximum="100" Value="{Binding BundleProgress}" />

            <ListBox
                ItemsSource="{Binding Projects}"
                SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                MouseDoubleClick="OnProjectListMouseDoubleClick"
                PreviewMouseRightButtonDown="OnProjectListPreviewMouseRightButtonDown">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="世代を保存" Click="OnSaveGenerationMenuClick" />
                        <MenuItem Header="世代一覧" Click="OnShowGenerationListMenuClick" />
                        <MenuItem Header="世代診断" Click="OnShowGenerationDiagnosticsMenuClick" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <controls:ScrubThumbnailControl
                                Grid.Column="0"
                                CacheDirectory="{Binding ThumbnailCacheDirectory}" />

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding EffectiveDisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding FullPath}" FontSize="11" Opacity="0.8" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
