<UserControl
    x:Class="YMMProjectManager.Presentation.Views.ProjectListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="clr-namespace:YMMProjectManager.Presentation.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="OnLoaded"
    AllowDrop="True"
    PreviewDragOver="OnPreviewDragOver"
    Drop="OnDrop"
    MinWidth="320"
    MinHeight="240">
    <Grid Margin="8">
        <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <TextBlock Text="フォルダー" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="作成" Width="60" Margin="0,0,6,0" Command="{Binding AddFolderCommand}"/>
                <Button Content="名前変更" Width="70" Margin="0,0,6,0" Command="{Binding RenameFolderCommand}"/>
                <Button Content="削除" Width="60" Command="{Binding DeleteFolderCommand}"/>
            </StackPanel>
            <Button Content="未分類" Margin="0,0,0,6" Command="{Binding SetUncategorizedFilterCommand}"/>
            <ListBox ItemsSource="{Binding Folders}" SelectedItem="{Binding SelectedFolderFilter, Mode=TwoWay}" DisplayMemberPath="Name"/>
        </StackPanel>
        <DockPanel Grid.Column="2">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                <Button Content="追加" Width="72" Margin="0,0,8,0" Command="{Binding AddCommand}" />
                <Button Content="削除" Width="72" Margin="0,0,8,0" Command="{Binding RemoveCommand}" />
                <Button Content="開く" Width="72" Margin="0,0,8,0" Command="{Binding OpenCommand}" />
                <Button Content="フォルダーへ分類" Width="110" Command="{Binding AssignSelectedProjectToFolderCommand}" />
            </StackPanel>
            <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="140"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="関連 .ymmp" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="追加" Width="60" Margin="0,0,6,0" Command="{Binding AddLinkedYmmpCommand}"/>
                    <Button Content="削除" Width="60" Margin="0,0,6,0" Command="{Binding RemoveLinkedYmmpCommand}"/>
                    <Button Content="保存" Width="60" Command="{Binding SaveLinkedYmmpCommand}"/>
                </StackPanel>
                <DataGrid Grid.Row="2" ItemsSource="{Binding SelectedProject.LinkedYmmpFiles}" SelectedItem="{Binding SelectedLinkedYmmp, Mode=TwoWay}" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="表示名" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridComboBoxColumn Header="Role" Width="90" SelectedItemBinding="{Binding Role, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding DataContext.RoleOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Memo" Binding="{Binding Memo, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                        <DataGridCheckBoxColumn Header="Exists" Binding="{Binding Exists}" Width="60" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            <ListBox ItemsSource="{Binding FilteredProjects}" SelectedItem="{Binding SelectedProject, Mode=TwoWay}" MouseDoubleClick="OnProjectListMouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <controls:ScrubThumbnailControl Grid.Column="0" CacheDirectory="{Binding ThumbnailCacheDirectory}" />
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"><TextBlock Text="{Binding EffectiveDisplayName}" FontWeight="SemiBold" /><TextBlock Text="{Binding FullPath}" FontSize="11" Opacity="0.8" /></StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
