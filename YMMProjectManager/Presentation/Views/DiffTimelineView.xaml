<UserControl
    x:Class="YMMProjectManager.Presentation.Views.DiffTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:YMMProjectManager.Presentation.ViewModels"
    xmlns:views="clr-namespace:YMMProjectManager.Presentation.Views"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DiffTimelineViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="前の差分" Width="90" Margin="0,0,8,0" Click="OnPrevDiffClick" />
            <Button Content="次の差分" Width="90" Margin="0,0,8,0" Click="OnNextDiffClick" />
            <Button Content="選択差分へ移動" Width="130" Margin="0,0,10,0" Click="OnScrollToSelectedClick" />
            <Separator Width="12" />
            <Button Content="縮小" Width="70" Margin="0,0,6,0" Click="OnZoomOutClick" />
            <Button Content="拡大" Width="70" Margin="0,0,6,0" Click="OnZoomInClick" />
            <Button Content="リセット" Width="70" Margin="0,0,10,0" Click="OnResetZoomClick" />
            <TextBlock VerticalAlignment="Center" Text="倍率:" Margin="0,0,4,0" />
            <TextBlock VerticalAlignment="Center" Text="{Binding Scale, StringFormat=F2}" Margin="0,0,10,0" />
            <TextBlock VerticalAlignment="Center" Text="モード:" Margin="0,0,4,0" />
            <TextBlock VerticalAlignment="Center" Text="{Binding ModeLabel}" Margin="0,0,10,0" />
            <TextBlock VerticalAlignment="Center" Text="同期:" Margin="0,0,4,0" />
            <TextBlock VerticalAlignment="Center" Text="{Binding SyncStateLabel}" Margin="0,0,10,0" />
            <TextBlock VerticalAlignment="Center" Text="表示中:" Margin="0,0,4,0" />
            <TextBlock VerticalAlignment="Center" Text="{Binding LastVisibleCount}" />
        </StackPanel>

        <views:DiffTimelineHeader Grid.Row="1" DataContext="{Binding}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,8,0" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                <ScrollViewer x:Name="TimelineScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollChanged="OnTimelineScrollChanged" PreviewMouseWheel="OnTimelinePreviewMouseWheel">
                    <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                        <ItemsControl ItemsSource="{Binding VisibleItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DiffTimelineItemViewModel}">
                                    <Button Width="{Binding Width}" Height="{Binding Height}" Click="OnTimelineItemClick" ToolTip="{Binding DisplayName}" BorderThickness="0" Padding="0" Background="Transparent">
                                        <Grid>
                                            <Rectangle Fill="{Binding Fill}" RadiusX="2" RadiusY="2" />
                                            <Rectangle Stroke="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" StrokeThickness="2" RadiusX="2" RadiusY="2">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Line
                            X1="{Binding CurrentFrameX}"
                            X2="{Binding CurrentFrameX}"
                            Y1="0"
                            Y2="{Binding CanvasHeight}"
                            Stroke="{DynamicResource {x:Static SystemColors.HotTrackBrushKey}}"
                            StrokeThickness="1.5"
                            StrokeDashArray="2,2"
                            IsHitTestVisible="False" />
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="8" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                <StackPanel>
                    <TextBlock Text="差分詳細" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="種別" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedDiffItem.Kind, TargetNullValue=-}" Margin="0,0,0,6" />
                    <TextBlock Text="項目" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedDiffItem.DisplayName, TargetNullValue=-}" Margin="0,0,0,6" />
                    <TextBlock Text="位置" FontWeight="SemiBold" />
                    <TextBlock Margin="0,0,0,6">
                        <Run Text="T=" /><Run Text="{Binding SelectedDiffItem.TimelineIndex}" />
                        <Run Text=", L=" /><Run Text="{Binding SelectedDiffItem.Layer}" />
                        <Run Text=", F=" /><Run Text="{Binding SelectedDiffItem.Frame}" />
                        <Run Text=", Len=" /><Run Text="{Binding SelectedDiffItem.Length}" />
                    </TextBlock>
                    <TextBlock Text="変更前" FontWeight="SemiBold" />
                    <TextBlock TextWrapping="Wrap" Text="{Binding SelectedDiffItem.OldValue, TargetNullValue=(なし)}" Margin="0,0,0,6" />
                    <TextBlock Text="変更後" FontWeight="SemiBold" />
                    <TextBlock TextWrapping="Wrap" Text="{Binding SelectedDiffItem.NewValue, TargetNullValue=(なし)}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
