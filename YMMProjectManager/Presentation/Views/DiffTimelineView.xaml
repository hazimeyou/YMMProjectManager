<UserControl
    x:Class="YMMProjectManager.Presentation.Views.DiffTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:YMMProjectManager.Presentation.ViewModels"
    xmlns:views="clr-namespace:YMMProjectManager.Presentation.Views"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DiffTimelineViewModel}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="LayerRowEvenBrush" Color="#262B33" />
        <SolidColorBrush x:Key="LayerRowOddBrush" Color="#2C313A" />
        <SolidColorBrush x:Key="LayerRowSeparatorBrush" Color="#1CFFFFFF" />
        <SolidColorBrush x:Key="ItemHoverOutlineBrush" Color="#66D7ECFF" />
        <Style x:Key="CompactHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="DetailsLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,1" />
        </Style>
        <Style x:Key="DetailsValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="前の差分" Width="90" Margin="0,0,8,0" Click="OnPrevDiffClick" />
            <Button Content="次の差分" Width="90" Margin="0,0,8,0" Click="OnNextDiffClick" />
            <Button Content="選択差分へ移動" Width="130" Margin="0,0,10,0" Click="OnScrollToSelectedClick" />
            <Separator Width="12" />
            <Button Content="縮小" Width="70" Margin="0,0,6,0" Click="OnZoomOutClick" />
            <Button Content="拡大" Width="70" Margin="0,0,6,0" Click="OnZoomInClick" />
            <Button Content="リセット" Width="70" Margin="0,0,10,0" Click="OnResetZoomClick" />
            <Button Content="25%" Width="58" Margin="0,0,4,0" Click="OnZoomPreset25Click" />
            <Button Content="50%" Width="58" Margin="0,0,4,0" Click="OnZoomPreset50Click" />
            <Button Content="100%" Width="58" Margin="0,0,4,0" Click="OnZoomPreset100Click" />
            <Button Content="200%" Width="58" Margin="0,0,8,0" Click="OnZoomPreset200Click" />
            <Button Content="全体表示" Width="80" Margin="0,0,10,0" Click="OnFitTimelineClick" />
            <TextBlock Style="{StaticResource CompactHeaderTextStyle}" Text="倍率:" />
            <TextBlock VerticalAlignment="Center" Text="{Binding Scale, StringFormat=F2}" Margin="0,0,10,0" />
            <TextBlock Style="{StaticResource CompactHeaderTextStyle}" Text="モード:" />
            <TextBlock VerticalAlignment="Center" Text="{Binding ModeLabel}" Margin="0,0,10,0" />
            <TextBlock Style="{StaticResource CompactHeaderTextStyle}" Text="同期:" />
            <TextBlock VerticalAlignment="Center" Text="{Binding SyncStateLabel}" Margin="0,0,10,0" />
            <TextBlock Style="{StaticResource CompactHeaderTextStyle}" Text="表示:" />
            <TextBlock VerticalAlignment="Center" Text="{Binding LastVisibleCount}" />
            <TextBlock Style="{StaticResource CompactHeaderTextStyle}" Text="投影:" Margin="10,0,0,0" />
            <TextBlock VerticalAlignment="Center" Text="{Binding ProjectedItemCount}" Margin="0,0,8,0" />
            <TextBlock Style="{StaticResource CompactHeaderTextStyle}" Text="最適化:" />
            <TextBlock VerticalAlignment="Center" Text="{Binding OptimizationMode}" Margin="0,0,8,0" />
            <CheckBox Content="一致を表示" IsChecked="{Binding ShowUnchangedItems, Mode=TwoWay}" Margin="10,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <views:DiffTimelineHeader Grid.Row="1" DataContext="{Binding}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,8,0" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                <ScrollViewer x:Name="TimelineScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollChanged="OnTimelineScrollChanged" PreviewMouseWheel="OnTimelinePreviewMouseWheel" MouseMove="OnTimelineMouseMove" MouseLeave="OnTimelineMouseLeave">
                    <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                        <ItemsControl IsHitTestVisible="False" ItemsSource="{Binding LayerRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="0" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="{Binding DataContext.CanvasWidth, RelativeSource={RelativeSource AncestorType=views:DiffTimelineView}}" Height="{Binding DataContext.RowHeight, RelativeSource={RelativeSource AncestorType=views:DiffTimelineView}}">
                                        <Border BorderBrush="{StaticResource LayerRowSeparatorBrush}" BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource LayerRowEvenBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Layer}" Value="1">
                                                            <Setter Property="Background" Value="{StaticResource LayerRowOddBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Layer}" Value="3">
                                                            <Setter Property="Background" Value="{StaticResource LayerRowOddBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Layer}" Value="5">
                                                            <Setter Property="Background" Value="{StaticResource LayerRowOddBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Layer}" Value="7">
                                                            <Setter Property="Background" Value="{StaticResource LayerRowOddBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Layer}" Value="9">
                                                            <Setter Property="Background" Value="{StaticResource LayerRowOddBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Text="{Binding Label}" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="#92FFFFFF" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl IsHitTestVisible="False" ItemsSource="{Binding RulerMarks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="0" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line X1="0" X2="0" Y1="0" Y2="{Binding DataContext.CanvasHeight, RelativeSource={RelativeSource AncestorType=views:DiffTimelineView}}" Stroke="#1FFFFFFF" StrokeThickness="1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding VisibleItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DiffTimelineItemViewModel}">
                                    <Button Width="{Binding Width}" Height="{Binding Height}" Click="OnTimelineItemClick" ToolTip="{Binding DisplayName}" BorderThickness="0" Padding="0" Background="Transparent">
                                        <Grid>
                                            <Rectangle Fill="{Binding Fill}" Opacity="{Binding ItemOpacity}" RadiusX="3" RadiusY="3" />
                                            <Border BorderBrush="#33000000" BorderThickness="1" Opacity="{Binding BorderOpacity}" CornerRadius="3" />
                                            <Grid Margin="5,2,5,2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel Grid.Row="0">
                                                    <TextBlock Text="{Binding ClipTypeLabel}" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                                                    <TextBlock Text="{Binding DurationHint}" DockPanel.Dock="Right" FontSize="9" Foreground="#DDEFFFFF" />
                                                </DockPanel>
                                                <DockPanel Grid.Row="1">
                                                    <TextBlock Text="{Binding ClipTitle}" FontSize="11" Foreground="White" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding LayerHint}" DockPanel.Dock="Right" FontSize="9" Foreground="#BFEFFFFF" Margin="4,0,0,0" />
                                                </DockPanel>
                                            </Grid>
                                            <Rectangle Stroke="{StaticResource ItemHoverOutlineBrush}" StrokeThickness="1.2" RadiusX="3" RadiusY="3">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>
                                            <Rectangle Stroke="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" StrokeThickness="1.6" RadiusX="3" RadiusY="3">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Line
                            X1="{Binding CurrentFrameX}"
                            X2="{Binding CurrentFrameX}"
                            Y1="0"
                            Y2="{Binding CanvasHeight}"
                            Stroke="{DynamicResource {x:Static SystemColors.HotTrackBrushKey}}"
                            StrokeThickness="1.5"
                            StrokeDashArray="2,2"
                            IsHitTestVisible="False" />
                        <Line x:Name="HoverFrameLine"
                              X1="0"
                              X2="0"
                              Y1="0"
                              Y2="{Binding CanvasHeight}"
                              Stroke="#80FFE082"
                              StrokeThickness="1.2"
                              Visibility="Collapsed"
                              IsHitTestVisible="False" />
                        <Border x:Name="HoverFrameBadge" Background="#CC1F2937" BorderBrush="#99FFE082" BorderThickness="1" CornerRadius="3" Padding="4,1" Visibility="Collapsed" IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <TextBlock x:Name="HoverFrameText" Foreground="#FFFDE68A" FontSize="10" />
                        </Border>
                        <Border Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" IsHitTestVisible="False">
                            <TextBlock Text="{Binding EmptyTimelineMessage}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#AAFFFFFF" FontSize="14" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasVisibleItems}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="7" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                <StackPanel>
                    <Border Background="#1E3F5A7A" BorderBrush="#333F5A7A" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="読み取り専用" FontWeight="SemiBold" FontSize="11" />
                            <TextBlock Text="復元・適用は無効です" FontSize="11" Opacity="0.9" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="選択詳細" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock Text="クリップ種別" Style="{StaticResource DetailsLabelTextStyle}" />
                    <TextBlock Text="{Binding SelectedDiffItem.ClipTypeLabel, TargetNullValue=-}" Style="{StaticResource DetailsValueTextStyle}" />
                    <TextBlock Text="種別" Style="{StaticResource DetailsLabelTextStyle}" />
                    <TextBlock Text="{Binding SelectedDiffItem.Kind, TargetNullValue=-}" Style="{StaticResource DetailsValueTextStyle}" />
                    <TextBlock Text="項目" Style="{StaticResource DetailsLabelTextStyle}" />
                    <TextBlock Text="{Binding SelectedDiffItem.ClipTitle, TargetNullValue=-}" Style="{StaticResource DetailsValueTextStyle}" />
                    <TextBlock Text="位置" Style="{StaticResource DetailsLabelTextStyle}" />
                    <Border Background="#123F4A5A" BorderBrush="#1C7A8CA6" BorderThickness="1" CornerRadius="3" Padding="5,4" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DetailsValueTextStyle}" Margin="0,0,0,2">
                                <Run Text="T=" /><Run Text="{Binding SelectedDiffItem.TimelineIndex}" />
                                <Run Text=", L=" /><Run Text="{Binding SelectedDiffItem.Layer}" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource DetailsValueTextStyle}" Margin="0,0,0,0">
                                <Run Text="開始F=" /><Run Text="{Binding SelectedDiffItem.Frame}" />
                                <Run Text=" / 終了F=" /><Run Text="{Binding SelectedDiffItem.EndFrame, Mode=OneWay}" />
                                <Run Text=" / 長さF=" /><Run Text="{Binding SelectedDiffItem.Length}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Expander Header="差分詳細（変更前）" IsExpanded="False">
                        <TextBlock TextWrapping="Wrap" Text="{Binding SelectedDiffItem.OldValue, TargetNullValue=(なし)}" Margin="0,3,0,6" FontSize="11" Opacity="0.9" />
                    </Expander>
                    <Expander Header="差分詳細（変更後）" IsExpanded="True" Margin="0,4,0,0">
                        <TextBlock TextWrapping="Wrap" Text="{Binding SelectedDiffItem.NewValue, TargetNullValue=(なし)}" Margin="0,3,0,0" FontSize="11" Opacity="0.9" />
                    </Expander>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
