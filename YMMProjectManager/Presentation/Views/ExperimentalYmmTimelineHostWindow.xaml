<Window
    x:Class="YMMProjectManager.Presentation.Views.ExperimentalYmmTimelineHostWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Experimental YMM Timeline Host"
    Width="1000"
    Height="700"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Status:" Margin="0,0,4,0" />
            <TextBlock Text="{Binding Status}" Margin="0,0,12,0" />
            <TextBlock Text="Init(ms):" Margin="0,0,4,0" />
            <TextBlock Text="{Binding InitializeMs}" Margin="0,0,12,0" />
            <TextBlock Text="Dispose(ms):" Margin="0,0,4,0" />
            <TextBlock Text="{Binding DisposeMs}" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#555" BorderThickness="1" Background="#111">
            <ContentControl Content="{Binding TimelineViewElement}" />
        </Border>

        <ListBox Grid.Row="2" Margin="0,8,0,0" ItemsSource="{Binding Logs}" />
    </Grid>
</Window>
