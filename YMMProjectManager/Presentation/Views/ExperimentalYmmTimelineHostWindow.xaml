<Window
    x:Class="YMMProjectManager.Presentation.Views.ExperimentalYmmTimelineHostWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Experimental YMM Timeline Host (Dry-run)"
    Width="1000"
    Height="700"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Status:" Margin="0,0,4,0" />
            <TextBlock Text="{Binding Status}" Margin="0,0,12,0" />
            <TextBlock Text="Init(ms):" Margin="0,0,4,0" />
            <TextBlock Text="{Binding InitializeMs}" Margin="0,0,12,0" />
            <TextBlock Text="Dispose(ms):" Margin="0,0,4,0" />
            <TextBlock Text="{Binding DisposeMs}" Margin="0,0,12,0" />
            <TextBlock Text="Readiness:" Margin="0,0,4,0" />
            <TextBlock Text="{Binding ReadinessScore}" Margin="0,0,12,0" />
            <TextBlock Text="CanVM:" Margin="0,0,4,0" />
            <TextBlock Text="{Binding CanAttemptViewModelGeneration}" Margin="0,0,12,0" />
            <TextBlock Text="CanView:" Margin="0,0,4,0" />
            <TextBlock Text="{Binding CanAttemptViewGeneration}" />
        </StackPanel>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="再判定〜保存を一括実行" Width="180" Margin="0,0,6,0" Click="OnRunAllDiagnosticsClick" />
            <Button Content="実行環境を再判定" Width="140" Margin="0,0,6,0" Click="OnRedetectRuntimeClick" />
            <Button Content="Reflection Probe 実行" Width="150" Margin="0,0,6,0" Click="OnRunProbeClick" />
            <Button Content="Binding Dry-run 実行" Width="150" Margin="0,0,6,0" Click="OnRunBindingDryRunClick" />
            <Button Content="生成試行(即破棄)" Width="130" Margin="0,0,6,0" Click="OnRunGenerationAttemptClick" />
            <Button Content="Diagnostics JSON 保存" Width="170" Click="OnSaveDiagnosticsClick" />
        </StackPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="Reflection コピー" Width="120" Margin="0,0,6,0" Click="OnCopyReflectionClick" />
            <Button Content="Binding コピー" Width="110" Margin="0,0,6,0" Click="OnCopyBindingClick" />
            <Button Content="Generation コピー" Width="120" Margin="0,0,6,0" Click="OnCopyGenerationClick" />
            <Button Content="Dispose コピー" Width="100" Margin="0,0,6,0" Click="OnCopyDisposeClick" />
            <Button Content="Logs コピー" Width="90" Click="OnCopyLogsClick" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Experimental generation attempt is disabled by default." FontWeight="SemiBold" />
            <TextBlock Text="{Binding RuntimeKindText, StringFormat=実行環境: {0}}" />
            <TextBlock Text="{Binding RuntimeProcessName, StringFormat=プロセス: {0}}" />
            <TextBlock Text="{Binding ReflectionSummary}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding TimelineViewType, StringFormat=TimelineView: {0}}" />
            <TextBlock Text="{Binding TimelineViewModelType, StringFormat=TimelineViewModel: {0}}" />
            <TextBlock Text="{Binding SetTimelineToolInfoOwnerType, StringFormat=SetTimelineToolInfo Owner: {0}}" />
            <TextBlock Text="これは実験的な診断です。TimelineView / TimelineViewModel の型探索のみを行います。既定では生成を行いません。失敗しても DiffTimeline は継続利用できます。" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Found Assemblies" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding FoundAssemblies}" />
            </GroupBox>
            <GroupBox Grid.Column="1" Header="Constructors" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding ConstructorSignatures}" />
            </GroupBox>
            <GroupBox Grid.Column="2" Header="Missing Dependencies">
                <ListBox ItemsSource="{Binding MissingDependencies}" />
            </GroupBox>
        </Grid>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="Constructor Binding Results" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding ConstructorBindingSummary}" />
            </GroupBox>
            <GroupBox Grid.Column="1" Header="YMM Related Assemblies" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding YmmRelatedAssemblies}" />
            </GroupBox>
            <GroupBox Grid.Column="2" Header="Blocking Reasons" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding BlockingReasons}" />
            </GroupBox>
            <GroupBox Grid.Column="3" Header="Warnings">
                <ListBox ItemsSource="{Binding ReadinessWarnings}" />
            </GroupBox>
        </Grid>

        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="Generation Attempt Result" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{Binding GenerationAttempted, StringFormat=Attempted: {0}}" />
                    <TextBlock Text="{Binding GenerationSucceeded, StringFormat=Succeeded: {0}}" />
                    <TextBlock Text="{Binding NullInjectedParameters, StringFormat=NullInjected: {0}}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GenerationConstructorSignature, StringFormat=Constructor: {0}}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GenerationFailureReason, StringFormat=Failure: {0}}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GenerationException, StringFormat=Exception: {0}}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GenerationStackTrace, StringFormat=StackTrace: {0}}" TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>
            <GroupBox Grid.Column="1" Header="Dispose Result">
                <StackPanel>
                    <TextBlock Text="{Binding TimelineViewGenerationAttempted, StringFormat=ViewAttempted: {0}}" />
                    <TextBlock Text="{Binding TimelineViewGenerationSucceeded, StringFormat=ViewSucceeded: {0}}" />
                    <TextBlock Text="{Binding TimelineViewGenerationFailureReason, StringFormat=ViewFailure: {0}}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding TimelineViewVisualAttachAttempted, StringFormat=ViewAttachAttempted: {0}}" />
                    <TextBlock Text="{Binding TimelineViewVisualAttachSucceeded, StringFormat=ViewAttachSucceeded: {0}}" />
                    <TextBlock Text="{Binding TimelineViewDetachSucceeded, StringFormat=ViewDetachSucceeded: {0}}" />
                    <TextBlock Text="{Binding TimelineViewAttachDurationMs, StringFormat=ViewAttachDurationMs: {0}}" />
                    <TextBlock Text="{Binding TimelineViewLoadedObserved, StringFormat=ViewLoadedObserved: {0}}" />
                    <TextBlock Text="{Binding TimelineViewInitializedObserved, StringFormat=ViewInitializedObserved: {0}}" />
                    <TextBlock Text="{Binding TimelineViewDataContextChangedObserved, StringFormat=ViewDataContextChangedObserved: {0}}" />
                    <TextBlock Text="{Binding TimelineViewTemplateAppliedObserved, StringFormat=ViewTemplateAppliedObserved: {0}}" />
                    <TextBlock Text="{Binding TimelineViewLayoutUpdatedObserved, StringFormat=ViewLayoutUpdatedObserved: {0}}" />
                    <TextBlock Text="{Binding TimelineViewRenderingObserved, StringFormat=ViewRenderingObserved: {0}}" />
                    <TextBlock Text="{Binding TimelineViewWeakReferenceAfterGc, StringFormat=ViewWeakRefAliveAfterGc: {0}}" />
                    <TextBlock Text="{Binding DisposeAttempted, StringFormat=DisposeAttempted: {0}}" />
                    <TextBlock Text="{Binding DisposeSucceeded, StringFormat=DisposeSucceeded: {0}}" />
                    <TextBlock Text="{Binding DisposeFailureReason, StringFormat=DisposeFailure: {0}}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GcVerificationAttempted, StringFormat=GCCheck: {0}}" />
                    <TextBlock Text="{Binding WeakReferenceAfterGc, StringFormat=WeakRefAliveAfterGc: {0}}" />
                    <TextBlock Text="{Binding FinalizationNote, StringFormat=FinalizationNote: {0}}" TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>
        </Grid>

        <ListBox Grid.Row="5" Margin="0,8,0,0" ItemsSource="{Binding Logs}" />
    </Grid>
</Window>


