<Window
    x:Class="YMMProjectManager.Presentation.Checkpoint.CheckpointDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="チェックポイント詳細"
    Width="1100"
    Height="760"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding CheckpointName}" />
            <TextBlock Margin="0,4,0,0" Text="{Binding SummaryText}" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="ymmp / ymmpx 情報" />
                <TextBlock Margin="0,8,0,0" Text="{Binding YmmpPath}" TextWrapping="Wrap" />
                <TextBlock Margin="0,4,0,0" Text="{Binding YmmpxPath}" TextWrapping="Wrap" />
                <TextBlock Margin="0,12,0,0" Text="{Binding CommentText}" TextWrapping="Wrap" />
                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="拡大表示" />
                <Border Margin="0,8,0,0" BorderBrush="#CCCCCC" BorderThickness="1" MinHeight="200">
                    <Image Source="{Binding SelectedThumbnail}" Stretch="Uniform" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ListBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ThumbnailItems}" SelectedItem="{Binding SelectedThumbnailItem, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <Border Width="144" Height="81" BorderBrush="#CCCCCC" BorderThickness="1">
                            <Image Source="{Binding Image}" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding Path}" TextWrapping="Wrap" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
