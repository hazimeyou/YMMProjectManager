<Window
    x:Class="YMMProjectManager.Presentation.Checkpoint.CheckpointDiagnosticsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="チェックポイント診断"
    Width="900"
    Height="620"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding WindowTitle}" />
            <TextBlock Margin="0,4,0,0" Text="{Binding SummaryText}" TextWrapping="Wrap" />
        </StackPanel>

        <Button DockPanel.Dock="Bottom" Width="96" HorizontalAlignment="Right" Content="閉じる" Click="OnCloseClick" />

        <DataGrid
            ItemsSource="{Binding Items}"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            CanUserAddRows="False"
            HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="判定" Binding="{Binding SeverityText}" Width="100" />
                <DataGridTextColumn Header="項目" Binding="{Binding Title}" Width="180" />
                <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
