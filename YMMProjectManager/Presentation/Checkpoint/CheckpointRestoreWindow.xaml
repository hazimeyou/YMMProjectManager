<Window
    x:Class="YMMProjectManager.Presentation.Checkpoint.CheckpointRestoreWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="チェックポイント復元"
    Width="620"
    Height="280"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,12" Text="チェックポイントは既存プロジェクトへ上書きせず、指定フォルダーへ ymmpx を展開して復元します。" TextWrapping="Wrap" />
        <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,12" Foreground="#666666" Text="復元先フォルダーには復元済みの .ymmp と素材ファイルが出力されます。" TextWrapping="Wrap" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="復元先" />
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,8,12" Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />
        <Button Grid.Row="2" Grid.Column="2" Width="96" Margin="0,0,0,12" Content="参照" Click="OnBrowseClick" />

        <TextBlock Grid.Row="3" Grid.ColumnSpan="3" Foreground="#666666" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Width="96" Margin="0,0,8,0" Content="復元" Click="OnRestoreClick" />
            <Button Width="96" Content="閉じる" Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
