<Window
    x:Class="YMMProjectManager.Presentation.Checkpoint.CheckpointCreateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="チェックポイント作成"
    Width="560"
    Height="460"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12" Text="チェックポイントは、後から見返したい大きな保存地点です。ymmp / ymmpx / サムネイル / Git情報をまとめて保存します。" TextWrapping="Wrap" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="名前" />
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" Text="{Binding CheckpointName, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="説明" />
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Top" Text="コメント" />
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" Height="72" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="96" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" Text="生成方式" />
                <ComboBox Grid.Column="1" Margin="0,0,8,0" ItemsSource="{Binding ModeItems}" SelectedValuePath="Tag" DisplayMemberPath="Content" SelectedValue="{Binding SelectedMode}" />
                <TextBox Grid.Column="2" Text="{Binding CustomValue}" />
            </Grid>
            <TextBlock Foreground="#666666" Text="サムネイル生成には、対象プロジェクトを YMM で開いた状態が必要です。任意秒数 / 任意分数では右の数値を使用します。" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Width="96" Margin="0,0,8,0" Content="作成" Click="OnOkClick" />
            <Button Width="96" Content="キャンセル" Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
