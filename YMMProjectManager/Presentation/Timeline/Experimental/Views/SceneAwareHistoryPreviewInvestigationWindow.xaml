<Window x:Class="YMMProjectManager.Presentation.Timeline.Experimental.Views.SceneAwareHistoryPreviewInvestigationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scene-aware History Preview Investigation"
        Width="1240" Height="860"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="RouteB Scene-aware History Preview Investigation (read-only)" FontWeight="SemiBold" FontSize="14"/>
        <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="{Binding SummaryText}"/>

        <GroupBox Grid.Row="2" Header="Runtime Context" Margin="0,8,0,0">
            <TextBlock Margin="6" Text="{Binding TimelineInfoText}" TextWrapping="Wrap"/>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Timeline Candidates" Margin="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Margin="6" Text="{Binding CandidatesText}" TextWrapping="Wrap" FontFamily="Consolas"/>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="Scene-aware History Matches" Margin="0,8,0,0">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding HistoryPreviewSummaryText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                <ListBox Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding HistoryPreviewItems}" SelectedItem="{Binding SelectedHistoryPreviewItem}" DisplayMemberPath="SummaryText"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="Selected History Preview Item Detail" Margin="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Margin="6" Text="{Binding SelectedHistoryPreviewItemDetailText}" TextWrapping="Wrap" FontFamily="Consolas"/>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="RouteA Handoff / Open Readiness" Margin="0,8,0,0">
            <StackPanel Margin="6">
                <TextBlock Text="{Binding HeavyProjectWarningText}" Foreground="OrangeRed" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding RouteADetailHandoffStatusText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                <Button Margin="0,6,0,0" Content="Open RouteA Detail Preview (Read-only)" IsEnabled="{Binding CanOpenRouteADetailDiff}" Click="OpenRouteADetailPreview_OnClick"/>
                <TextBlock Margin="0,6,0,0" Text="{Binding RouteADetailOpenResultText}" TextWrapping="Wrap" FontFamily="Consolas"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="7" Header="Diagnostics" Margin="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Margin="6" Text="{Binding DiagnosticsText}" TextWrapping="Wrap" FontFamily="Consolas"/>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Row="8" Header="RC / Safety" Margin="0,8,0,0">
            <StackPanel Margin="6">
                <TextBlock Text="{Binding RcStatusText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                <TextBlock Margin="0,6,0,0" Text="Preview Feature Gate" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding PreviewFeatureStatusText}" TextWrapping="Wrap" FontFamily="Consolas"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
