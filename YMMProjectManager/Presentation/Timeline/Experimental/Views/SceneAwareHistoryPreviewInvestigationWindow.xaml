<Window x:Class="YMMProjectManager.Presentation.Timeline.Experimental.Views.SceneAwareHistoryPreviewInvestigationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scene-aware History Preview (Preview Candidate)"
        Width="1240" Height="860"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Scene-aware History Preview (Read-only / Experimental)" FontWeight="SemiBold" FontSize="14"/>
        <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="{Binding SummaryText}"/>
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,6,0,0">
            <Button Width="240" Content="Rerun (absolute paths)" Click="RerunInvestigation_OnClick"/>
            <TextBlock Margin="0,6,0,0" Text="{Binding OutputPathsText}" TextWrapping="Wrap" FontFamily="Consolas"/>
        </StackPanel>

        <GroupBox Grid.Row="3" Header="1. Current Scene" Margin="0,8,0,0">
            <TextBlock Margin="6" Text="{Binding CurrentSceneText}" TextWrapping="Wrap"/>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="2. Related History" Margin="0,8,0,0">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding HistoryPreviewSummaryText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="{Binding RelatedHistoryStatusText}" TextWrapping="Wrap"/>
                <ListBox Grid.Row="2" Margin="0,6,0,0" ItemsSource="{Binding HistoryPreviewItems}" SelectedItem="{Binding SelectedHistoryPreviewItem}" DisplayMemberPath="SummaryText"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="3. Match Reason" Margin="0,8,0,0">
            <StackPanel Margin="6">
                <TextBlock Text="{Binding MatchReasonText}" TextWrapping="Wrap"/>
                <TextBlock Margin="0,6,0,0" Text="{Binding SelectedHistoryPreviewItemDetailText}" TextWrapping="Wrap" FontFamily="Consolas"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="7" Header="4. RouteA Detail Preview" Margin="0,8,0,0">
            <StackPanel Margin="6">
                <TextBlock Text="{Binding RouteADetailPreviewText}" TextWrapping="Wrap"/>
                <Button Margin="0,6,0,0" Content="RouteA detail (read-only preview)" IsEnabled="{Binding CanOpenRouteADetailDiff}" Click="OpenRouteADetailPreview_OnClick"/>
                <TextBlock Margin="0,6,0,0" Text="{Binding RouteADetailOpenResultText}" TextWrapping="Wrap" FontFamily="Consolas"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="8" Header="5. Diagnostics / Safety" Margin="0,8,0,0">
            <StackPanel Margin="6">
                <TextBlock Text="{Binding DiagnosticsSafetyText}" TextWrapping="Wrap"/>
                <Expander Header="Diagnostics details" Margin="0,6,0,0" IsExpanded="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Margin="4" Text="{Binding DiagnosticsText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </ScrollViewer>
                </Expander>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="9" Header="Preview Gate / RC" Margin="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="6">
                    <TextBlock Text="{Binding RcStatusText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                    <TextBlock Margin="0,6,0,0" Text="{Binding PreviewFeatureStatusText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>

