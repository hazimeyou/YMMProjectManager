<Window x:Class="YMMProjectManager.Presentation.Timeline.Experimental.Views.SceneAwareHistoryPreviewInvestigationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="履歴プレビュー（読み取り専用）"
        Width="1380" Height="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="8" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="履歴プレビュー（読み取り専用）" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Margin="0,4,0,0" Text="{Binding SummaryText}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Width="170" Content="履歴を再読み込み" Click="RerunInvestigation_OnClick"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <GroupBox Grid.Row="1" Header="現在シーン / 状態" Margin="0,8,0,0">
            <TextBlock Margin="6" Text="{Binding CurrentSceneText}" TextWrapping="Wrap"/>
        </GroupBox>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="関連履歴">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding HistoryPreviewSummaryText}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="{Binding RelatedHistoryStatusText}" TextWrapping="Wrap"/>
                    <ListBox Grid.Row="2" Margin="0,6,0,0" ItemsSource="{Binding HistoryPreviewItems}" SelectedItem="{Binding SelectedHistoryPreviewItem}" DisplayMemberPath="SummaryText"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="履歴タイムライン（読み取り専用）" Margin="8,0,8,0">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="履歴差分を表示しています（読み取り専用モード）" Opacity="0.8"/>
                    <Border Grid.Row="1" Margin="0,6,0,0" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Background="#FFF6F6F6">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="選択中の履歴候補の差分は、右側の詳細と RouteA 詳細ビューで確認できます。" TextWrapping="Wrap" Margin="20"/>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="詳細 / 安全状態">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding MatchReasonText}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="{Binding RouteADetailPreviewText}" TextWrapping="Wrap"/>
                    <Button Grid.Row="2" Margin="0,8,0,0" Content="RouteA詳細を開く（読み取り専用）" IsEnabled="{Binding CanOpenRouteADetailDiff}" Click="OpenRouteADetailPreview_OnClick"/>
                    <TextBlock Grid.Row="3" Margin="0,8,0,0" Text="{Binding RouteADetailOpenResultText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                </Grid>
            </GroupBox>
        </Grid>

        <Expander Grid.Row="3" Header="▼ 詳細 diagnostics" Margin="0,8,0,0" IsExpanded="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="6" Text="{Binding DiagnosticsSafetyText}" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Margin="6">
                    <TextBlock Text="{Binding RcStatusText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                    <TextBlock Margin="0,6,0,0" Text="{Binding PreviewFeatureStatusText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                    <TextBlock Margin="0,6,0,0" Text="{Binding OutputPathsText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                </StackPanel>
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <TextBlock Margin="6" Text="{Binding DiagnosticsText}" TextWrapping="Wrap" FontFamily="Consolas"/>
                </ScrollViewer>
            </Grid>
        </Expander>
    </Grid>
</Window>

