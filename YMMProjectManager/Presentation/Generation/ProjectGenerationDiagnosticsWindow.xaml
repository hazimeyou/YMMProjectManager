<Window
    x:Class="YMMProjectManager.Presentation.Generation.ProjectGenerationDiagnosticsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="世代診断"
    Width="860"
    Height="520"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12" Text="保存状態の確認用情報です。" />

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
            <UniformGrid Columns="2" Rows="4" Margin="0,0,0,12">
                <TextBlock Text="ProjectId" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ProjectId}" TextWrapping="Wrap" />

                <TextBlock Text="ProjectPath" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ProjectPath}" TextWrapping="Wrap" />

                <TextBlock Text="GenerationCount" FontWeight="SemiBold" />
                <TextBlock Text="{Binding GenerationCount}" />

                <TextBlock Text="StorageSize" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StorageSizeText}" />
            </UniformGrid>

            <UniformGrid Columns="2" Rows="4">
                <TextBlock Text="LatestGeneration" FontWeight="SemiBold" />
                <TextBlock Text="{Binding LatestGenerationText}" TextWrapping="Wrap" />

                <TextBlock Text="ManifestStatus" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ManifestStatus}" />

                <TextBlock Text="DeletedGenerationCount" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DeletedGenerationCount}" />

                <TextBlock Text="最新作成日時" FontWeight="SemiBold" />
                <TextBlock Text="{Binding LatestGenerationCreatedAtText}" />
            </UniformGrid>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="96" Margin="0,0,8,0" Content="更新" Click="OnRefreshClick" />
            <Button Width="96" Content="閉じる" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
